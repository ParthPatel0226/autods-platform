# AutoDS API — environment variables
# Copy to .env and fill in real values. Never commit .env.

# ── Runtime ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins (parsed as JSON list by pydantic-settings)
ALLOWED_ORIGINS=["http://localhost:3000"]
# Regex matched against Origin header (for Vercel preview deployments)
ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # anon/public key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret             # Settings > API > JWT Secret

# ── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy...

# ── Internal JWT (used when SUPABASE_JWT_SECRET is not set) ──────────────────
JWT_SECRET=change-me-in-production                       # long random string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440                                  # 24 hours

# ── Limits ───────────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=250

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
