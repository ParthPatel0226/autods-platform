# AutoDS Platform — Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Configuration (REQUIRED — pick ONE provider)
# =============================================================================

# Which LLM provider to use (default: gemini)
# Options: gemini | ollama | anthropic | openai
AUTODS_LLM_PROVIDER=gemini

# --- Option 1: Gemma 4 via Google Gemini API (RECOMMENDED — cheapest hosted) ---
# Get FREE key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here
# AUTODS_LLM_MODEL=gemma-4-31b-it  # or gemma-4-26b-a4b-it

# --- Option 2: Gemma 4 via Ollama (FREE — runs locally) ---
# Install: https://ollama.com → ollama pull gemma4:26b
# AUTODS_LLM_PROVIDER=ollama
# AUTODS_LLM_MODEL=gemma4:26b  # or gemma4:4b for low-RAM machines
# OLLAMA_BASE_URL=http://localhost:11434

# --- Option 3: Claude via Anthropic API ---
# AUTODS_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# AUTODS_LLM_MODEL=claude-sonnet-4-20250514

# --- Option 4: OpenAI GPT ---
# AUTODS_LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# AUTODS_LLM_MODEL=gpt-4o

# General LLM settings (apply to all providers)
AUTODS_LLM_TEMPERATURE=0
AUTODS_LLM_MAX_TOKENS=4096

# =============================================================================
# Data Connectors (OPTIONAL — only needed if using these sources)
# =============================================================================

# Kaggle API (for downloading Kaggle datasets)
KAGGLE_USERNAME=
KAGGLE_KEY=

# Google BigQuery (service account JSON path)
GOOGLE_APPLICATION_CREDENTIALS=

# AWS S3 (for S3 bucket access)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=

# Snowflake
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=

# =============================================================================
# Platform Configuration
# =============================================================================

# Database paths (defaults are fine for local development)
AUTODS_DUCKDB_PATH=data/warehouse.duckdb
AUTODS_SQLITE_PATH=sessions/autods.db
AUTODS_CHROMADB_PATH=sessions/chromadb

# MLflow tracking
MLFLOW_TRACKING_URI=mlruns

# Logging
AUTODS_LOG_LEVEL=INFO
AUTODS_LOG_DIR=logs

# Session management
AUTODS_SESSION_DIR=sessions
AUTODS_MAX_SESSIONS=50

# Output directory
AUTODS_OUTPUT_DIR=outputs

# =============================================================================
# API Serving (for FastAPI prediction endpoint)
# =============================================================================
AUTODS_API_HOST=0.0.0.0
AUTODS_API_PORT=8000

# =============================================================================
# Cost Control
# =============================================================================
AUTODS_MAX_API_CALLS_PER_RUN=100
AUTODS_WARN_AT_COST_USD=0.50
